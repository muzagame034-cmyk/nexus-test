# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/nexus_test_db
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/nexus_test_db

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRE=30d

# OpenAI API Key (for AI question generator)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@nexustest.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
